rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      let claims = request.auth.token;
      return claims.admin == true
        || claims.isAdmin == true;
    }

    function isSeniorPastor() {
      let claims = request.auth.token;
      return claims.seniorPastor == true
        || claims.isSeniorPastor == true;
    }

    function canWrite() {
      return isAdmin() || isSeniorPastor();
    }

    function canDelete() {
      return isAdmin();
    }

    match /auditLogs/{logId} {
      allow create: if isAuthenticated() && canWrite();
      allow read: if isAuthenticated() && isAdmin();
      allow update, delete: if false;
    }

    match /people/{personId} {
      allow create: if isAuthenticated() && canWrite();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && canWrite();
      allow delete: if isAuthenticated() && canDelete();
    }

    match /directoryIntakeSubmissions/{submissionId} {
      allow create: if request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.type is string
        && request.resource.data.type in ['Member', 'Volunteer', 'First Time', 'Returning', 'Guest', 'Child']
        && request.resource.data.firstName.size() > 0
        && request.resource.data.lastName.size() > 0
        && (
          (
            request.resource.data.type == 'Child'
            && request.resource.data.parents is string
            && request.resource.data.parents.size() > 0
            && request.resource.data.parentPhone is string
            && request.resource.data.parentPhone.size() > 0
          )
          ||
          (
            request.resource.data.type != 'Child'
            && (
              (request.resource.data.email is string && request.resource.data.email.size() > 0)
              || (request.resource.data.phone is string && request.resource.data.phone.size() > 0)
            )
          )
        );
      allow read: if isAuthenticated() && canWrite();
      allow update: if isAuthenticated() && canWrite();
      allow delete: if false;
    }

    match /events/{eventId} {
      allow create: if isAuthenticated() && canWrite();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && canWrite();
      allow delete: if isAuthenticated() && canDelete();
    }

    match /giving/{giftId} {
      allow create: if isAuthenticated() && isAdmin();
      allow read: if isAuthenticated() && isAdmin();
      allow update: if isAuthenticated() && isAdmin();
      allow delete: if isAuthenticated() && isAdmin();
    }

    match /donations/{donationId} {
      allow create: if isAuthenticated() && isAdmin();
      allow read: if isAuthenticated() && isAdmin();
      allow update: if isAuthenticated() && isAdmin();
      allow delete: if isAuthenticated() && isAdmin();
    }

    match /songs/{songId} {
      allow create: if isAuthenticated() && canWrite();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && canWrite();
      allow delete: if isAuthenticated() && canDelete();

      match /analyses/{analysisId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && canWrite();
        allow delete: if isAuthenticated() && canWrite();
        allow update: if false;
      }
    }

    match /teams/{teamId} {
      allow create: if isAuthenticated() && canWrite();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && canWrite();
      allow delete: if isAuthenticated() && canDelete();
    }

    match /workflows/{workflowId} {
      allow create: if isAuthenticated() && canWrite();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && canWrite();
      allow delete: if isAuthenticated() && canDelete();
    }

    match /communityPosts/{postId} {
      allow create: if isAuthenticated() && canWrite();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && canWrite();
      allow delete: if isAuthenticated() && (isAdmin() || (canWrite() && resource.data.authorId == request.auth.uid));
    }

    match /communityMessages/{messageId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
      allow update, delete: if isAuthenticated() && canWrite();
    }

    match /teamMessages/{messageId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
      allow update, delete: if isAuthenticated() && canWrite();
    }

    match /workflowInboxMessages/{messageId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
      allow update, delete: if isAuthenticated() && canWrite();
    }

    match /settings/{settingId} {
      allow create: if isAuthenticated() && canWrite();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && canWrite();
      allow delete: if false;
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isAuthenticated() && isAdmin();
    }
  }
}
