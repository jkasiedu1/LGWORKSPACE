# Firebase
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# Cloudflare Worker base URL  (all AI calls and admin APIs go through this Worker)
# The DeepSeek API key is stored as a Worker secret — NEVER put it here.
# To set the secret: cd r2-signer-worker && wrangler secret put DEEPSEEK_API_KEY
VITE_WORKER_BASE_URL=https://your-worker.workers.dev

VITE_R2_SIGNER_URL=https://your-r2-signer.your-domain.workers.dev/sign-upload
VITE_R2_MAX_IMAGE_MB=10
VITE_R2_MAX_VIDEO_MB=100
VITE_ROLE_ADMIN_API_URL=https://your-r2-signer.your-domain.workers.dev/roles/grant
VITE_USER_ADMIN_API_BASE_URL=https://your-r2-signer.your-domain.workers.dev/users
VITE_USE_FIREBASE_EMULATORS=false
VITE_USE_FIRESTORE_EMULATOR=false
VITE_USE_AUTH_EMULATOR=false
VITE_FIRESTORE_EMULATOR_HOST=127.0.0.1
VITE_FIRESTORE_EMULATOR_PORT=8085
VITE_AUTH_EMULATOR_HOST=127.0.0.1
VITE_AUTH_EMULATOR_PORT=9099

# r2-signer-worker environment variables
# ALLOWED_ORIGINS=https://lifegate.example.com,https://staging.lifegate.example.com
# FIREBASE_PROJECT_ID=lifegate-workspace-5dd48
# FIREBASE_WEB_API_KEY=your_firebase_web_api_key
# FIREBASE_SERVICE_ACCOUNT_EMAIL=firebase-adminsdk-xxxxx@lifegate-workspace-5dd48.iam.gserviceaccount.com
# FIREBASE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"