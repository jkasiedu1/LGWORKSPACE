VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_R2_SIGNER_URL=https://your-r2-signer.your-domain.workers.dev/sign-upload
VITE_R2_MAX_IMAGE_MB=10
VITE_R2_MAX_VIDEO_MB=100
VITE_ROLE_ADMIN_API_URL=https://your-r2-signer.your-domain.workers.dev/roles/grant
VITE_USE_FIREBASE_EMULATORS=false
VITE_USE_FIRESTORE_EMULATOR=false
VITE_USE_AUTH_EMULATOR=false
VITE_FIRESTORE_EMULATOR_HOST=127.0.0.1
VITE_FIRESTORE_EMULATOR_PORT=8085
VITE_AUTH_EMULATOR_HOST=127.0.0.1
VITE_AUTH_EMULATOR_PORT=9099

